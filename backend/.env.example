# ── Database ──────────────────────────────────────────────────────────────────
# AWS RDS PostgreSQL connection string.
# Format: postgresql+psycopg://USER:PASSWORD@RDS_ENDPOINT:5432/DBNAME
DATABASE_URL=postgresql+psycopg://daai_user:change-me@your-rds-endpoint.rds.amazonaws.com:5432/daai

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
UPLOAD_DIR=uploads

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_SESSION_HOURS=12
# Email address to receive contact form submissions
ADMIN_NOTIFY_EMAIL=

# Admin IP allowlist (optional).
# Leave empty to allow any IP — admin login password is the primary protection.
# Set to a specific IP or use a VPN so your IP is always the same.
# Example: ADMIN_ALLOWED_IPS=203.0.113.42
ADMIN_ALLOWED_IPS=

# ── AWS SES (email) ───────────────────────────────────────────────────────────
# The sender email address — must be verified in AWS SES before use.
# In SES sandbox mode only verified recipient addresses can receive emails.
# Request production access to send to any address.
SES_SENDER_EMAIL=no-reply@daai.org
SES_SENDER_NAME=DAAI Fellowship
AWS_SES_REGION=us-east-1

# ── AWS credentials ───────────────────────────────────────────────────────────
# Set these when running locally or in environments without an IAM instance role.
# On EC2 / ECS / Lambda with an IAM role attached, leave these blank.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=    # only needed for temporary STS credentials
